    {
      "parameters": {
        "jsCode": "const output = $json.output || {};\n\n// Dados do e-mail/PDF vindos do node Filtrar 1 PDF\nlet dadosEmail = {};\nlet dadosBinary = {};\n\ntry {\n  const pdfNode = $('Filtrar 1 PDF').first();\n  dadosEmail = pdfNode.json || {};\n  dadosBinary = pdfNode.binary || {};\n} catch (error) {\n  dadosEmail = {};\n  dadosBinary = {};\n}\n\nreturn {\n  json: {\n    // Dados do candidato extraídos pela IA\n    cand_nome: output.nome || '',\n    cand_email: String(output.email || '').toLowerCase().trim(),\n    cand_telefone: output.telefone || '',\n    cand_cidade: output.cidade || '',\n    cand_linkedin: output.linkedin || '',\n    cand_cargo_desejado: output.cargo_desejado || '',\n    cand_area_principal: output.area_principal || '',\n    cand_senioridade: output.senioridade || '',\n    cand_resumo_ia: output.resumo_ia || '',\n    cand_habilidades_tecnicas: output.habilidades_tecnicas || '',\n    cand_habilidades_comportamentais: output.habilidades_comportamentais || '',\n    cand_formacao: output.formacao || '',\n    cand_experiencia_anos: output.experiencia_anos || '',\n    cand_status_funil: output.status_funil || 'Analisado pela IA',\n    cand_observacoes: output.observacoes || '',\n\n    // Dados do e-mail original\n    email_id: dadosEmail.email_id || '',\n    thread_id: dadosEmail.thread_id || '',\n    assunto_email: dadosEmail.assunto || '',\n    remetente: dadosEmail.remetente || '',\n    remetente_email: dadosEmail.remetente_email || '',\n    arquivo_nome: dadosEmail.arquivo_nome || ''\n  },\n  binary: dadosBinary\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        -704
      ],
      "id": "75b7b2cf-06f3-4473-b03b-c3f0581a0724",
      "name": "Preparar dados do candidato"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nif (items.length === 0) {\n  return [];\n}\n\nconst item = items[0];\nconst binaries = item.binary || {};\n\n// Pega dados do e-mail selecionado no node anterior\nconst emailSelecionado = $('Selecionar 1 e-mail').first().json;\n\n// Assunto\nconst assunto =\n  emailSelecionado.subject ||\n  emailSelecionado.Subject ||\n  item.json.subject ||\n  item.json.Subject ||\n  '';\n\n// Remetente bruto\nconst fromRaw =\n  emailSelecionado.from ||\n  emailSelecionado.From ||\n  item.json.from ||\n  item.json.From ||\n  '';\n\n// Trata remetente quando vem como array de objeto\nlet remetenteNome = '';\nlet remetenteEmail = '';\n\nif (Array.isArray(fromRaw) && fromRaw.length > 0) {\n  remetenteNome = fromRaw[0].name || '';\n  remetenteEmail = fromRaw[0].address || '';\n} else if (typeof fromRaw === 'object' && fromRaw !== null) {\n  remetenteNome = fromRaw.name || '';\n  remetenteEmail = fromRaw.address || fromRaw.email || '';\n} else if (typeof fromRaw === 'string') {\n  const match = fromRaw.match(/<([^>]+)>/);\n  const emailMatch = fromRaw.match(/[^\\s<>\"]+@[^\\s<>\"]+\\.[^\\s<>\"]+/);\n\n  remetenteEmail = match ? match[1] : emailMatch ? emailMatch[0] : fromRaw;\n  remetenteNome = fromRaw.replace(/<[^>]+>/, '').trim();\n}\n\nconst remetenteFormatado = remetenteNome && remetenteEmail\n  ? `${remetenteNome} <${remetenteEmail}>`\n  : remetenteEmail;\n\n// Procura o primeiro PDF no binary\nfor (const [binaryKey, file] of Object.entries(binaries)) {\n  const fileName = file.fileName || '';\n  const mimeType = file.mimeType || '';\n\n  const isPdf =\n    mimeType === 'application/pdf' ||\n    fileName.toLowerCase().endsWith('.pdf');\n\n  if (isPdf) {\n    return [\n      {\n        json: {\n          email_id: item.json.id || emailSelecionado.email_id || emailSelecionado.id || '',\n          thread_id: item.json.threadId || emailSelecionado.threadId || '',\n          assunto: assunto,\n          remetente: remetenteFormatado,\n          remetente_email: remetenteEmail,\n          arquivo_nome: fileName || `curriculo_${Date.now()}.pdf`,\n          binary_original: binaryKey\n        },\n        binary: {\n          data: file\n        }\n      }\n    ];\n  }\n}\n\nreturn [];"
      },
