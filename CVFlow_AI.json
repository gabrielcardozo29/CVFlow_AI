    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nif (items.length === 0) {\n  return [];\n}\n\nfunction getTime(item) {\n  const json = item.json || {};\n\n  if (json.internalDate) {\n    return Number(json.internalDate);\n  }\n\n  if (json.date) {\n    return new Date(json.date).getTime();\n  }\n\n  if (json.Date) {\n    return new Date(json.Date).getTime();\n  }\n\n  return 0;\n}\n\n// Ordena do mais antigo para o mais recente\nitems.sort((a, b) => getTime(a) - getTime(b));\n\n// Seleciona apenas o primeiro da fila\nconst selected = items[0];\n\nreturn [\n  {\n    json: {\n      ...selected.json,\n      email_id: selected.json.id,\n      selecionado_para_processamento: true\n    }\n  }\n];"
      },
